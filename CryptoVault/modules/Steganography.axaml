<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CryptoVault.modules.Steganography">
        <Grid ColumnDefinitions="*,*" RowDefinitions="4*, 5*, *">
            <Grid ColumnDefinitions="*,*">
                <Border Background="LightGray" Margin="5">
                    <Image Name="ImageBox"/>
                </Border>
                <Button Name="btnImageSelect" Click="SelectImage" Grid.Column="1" Content="Choisir un fichier" HorizontalAlignment="Center"/>
            </Grid>
            
            <TextBox Name="tbxContent" Grid.Row="1" Margin="7" AcceptsReturn="True" Text="{Binding FileContent, Mode=TwoWay}"/>
            
            <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="*,*">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Mot de passe"/>
                    <TextBox Name="tbxPassword" PasswordChar="*"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="30">
                    <Button Click="HideData" Content="Cacher" FontSize="24" Padding="20, 10"/>
                    <Button Click="UnHide" Content="Revéler" FontSize="24" Padding="20, 10"/>
                </StackPanel>
            </Grid>
            
            <Grid Grid.Row="2" Margin="7" ColumnDefinitions="*,*">
                <Button Name="BtnLoadFile" Click="LoadFile" HorizontalAlignment="Left" Content="Charger un fichier"/>
                <Button Grid.Column="1" HorizontalAlignment="Right" Name="BtnDownloadFile" Click="DownloadFile" Content="Télécharge le fichier"/>
            </Grid>
        </Grid>
</UserControl>
