<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CryptoVault.modules.PasswordAnalyzer">
        <Grid RowDefinitions="*, 2*" ColumnDefinitions="*, *">
                <TextBox Name="tbxPasswordAnalyzer" Grid.ColumnSpan="2" Height="15" Margin="150, 0" PlaceholderText="Entrez votre mot de passe" TextChanged="AnalyzePassword"/>
                                
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,200,0">
                        <StackPanel.Styles>
                                <Style Selector="TextBlock">
                                        <Setter Property="FontSize" Value="16"/>
                                </Style>
                        </StackPanel.Styles>
                        
                        <TextBlock Text="☒" Name="tbkCaps"/>
                        <TextBlock Text="☑" Name="tbkLower"/>
                        <TextBlock Text="test" Name="tbkLenght"/>
                        <TextBlock Text="test" Name="tbkNumbers"/>
                        <TextBlock Text="test" Name="tbkSpecialChars"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Styles>
                                <Style Selector="TextBlock">
                                        <Setter Property="FontSize" Value="24"/>
                                </Style>
                        </StackPanel.Styles>
                        
                        <TextBlock Text="Robustesse: "/>
                        <TextBlock Text="Moyen" Name="tbkStrenght"/>
                </StackPanel>
        </Grid>
</UserControl>
