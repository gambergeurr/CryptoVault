<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Height="32"
             x:Class="CryptoVault.controls.CopyableTextbox">
    <Grid ColumnDefinitions="*, Auto">
        <TextBox Name="tbxContent"
                 Watermark="Aucun"
                 IsReadOnly="{Binding $parent[UserControl].IsReadOnly}"
                 PasswordChar="{Binding $parent[UserControl].PasswordChar}"
                 Text="{Binding $parent[UserControl].TbxText, Mode=TwoWay}"/>
        <Button Grid.Column="1" Padding="2" Click="Button_OnClick" VerticalAlignment="Stretch">
            <Image Source="avares://CryptoVault/images/copy.png"/>
        </Button>
    </Grid>

</UserControl>
