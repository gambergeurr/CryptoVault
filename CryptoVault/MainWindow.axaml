<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="700" Height="400"
        xmlns:modules="clr-namespace:CryptoVault.modules"
        x:Class="CryptoVault.MainWindow"
        Title="CryptoVault">
        <TabControl>
                <TabControl.Styles>
                        <Style Selector="TabItem">
                                <Setter Property="FontSize" Value="16"/>
                        </Style>
                </TabControl.Styles>
                <TabItem Header="Analyse de mot de passe">
                        <modules:PasswordAnalyzer/>
                </TabItem>
                        
                <TabItem Header="Gestionaire clées API" x:Name="tabApi">
                        <modules:LockedModule PasswordEntered="TryDecrypt"/>
                </TabItem>
                
                <TabItem Header="Fichiers sécurisés" x:Name="tabFiles">
                        <modules:LockedModule PasswordEntered="TryDecrypt"/>
                </TabItem>
                
                <TabItem Header="Stéganographie">
                        <modules:Steganography/>
                </TabItem>
        </TabControl>
</Window>
